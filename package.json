{
  "name": "belge-asistani",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --noEmit && vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync",
    "cap:doctor": "npx cap doctor",
    "android:add": "npx cap add android",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "npm run build && npx cap run android",
    "android:run:live": "npx cap run android --external",
    "android:apk:debug": "export JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home; export PATH=\"/opt/homebrew/opt/openjdk@21/bin:$PATH\"; cd android && ./gradlew assembleDebug",
    "android:install:debug": "export JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home; export PATH=\"/opt/homebrew/opt/openjdk@21/bin:$PATH\"; cd android && ./gradlew installDebug",
    "android:release": "export JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home; export PATH=\"/opt/homebrew/opt/openjdk@21/bin:$PATH\"; cd android && ./gradlew assembleRelease bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.1",
    "@capacitor/core": "^7.6.1",
    "@pdf-lib/fontkit": "^1.1.1",
    "@supabase/supabase-js": "^2.103.0",
    "lucide-react": "^1.7.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "react-signature-canvas": "^1.1.0-alpha.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-signature-canvas": "^1.0.7",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
